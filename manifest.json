{
  "schema": 2,
  "permissions": [],
  "required_executas": [],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the LitFlow AI app open. It runs a 5-stage literature-review pipeline (planning, source discovery from CrossRef/arXiv, insight extraction, gap discovery, literature review) and reaches the model via anna.llm.complete. You do not need to summon any windows.",
  "tags": ["research", "literature-review", "llm", "academic"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": [
        "https://api.crossref.org",
        "https://export.arxiv.org"
      ]
    },
    "views": [
      {
        "name": "main",
        "title": "LitFlow AI",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 520, "h": 640 },
        "default_size": { "w": 720, "h": 900 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "llm": ["complete"],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "script-src": ["'self'"],
      "connect-src": [
        "'self'",
        "https://api.crossref.org",
        "https://export.arxiv.org"
      ]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "user_id": 1
  }
}
